# Snuglo — App Store Connect API credentials (copy to secrets/.env.local)
# Create an API key in App Store Connect → Users and Access → Integrations → App Store Connect API.
# Role: Admin or App Manager (Game Center write needs App Manager+).

APP_STORE_KEY_ID=XXXXXXXXXX
APP_STORE_ISSUER_ID=00000000-0000-0000-0000-000000000000
# .p8 path, relative to repo root (or absolute). Keep the file inside secrets/.
APP_STORE_KEY_PATH=secrets/AuthKey_XXXXXXXXXX.p8
# The app's numeric ASC id (App Store Connect → App → App Information → Apple ID).
APP_STORE_APP_ID=0000000000
