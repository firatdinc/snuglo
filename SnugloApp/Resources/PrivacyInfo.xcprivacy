<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The app's own first-party code performs no tracking. Tracking (and its
         domains) is declared by the bundled GoogleMobileAds SDK's privacy manifest
         per Google's guidance — so this app-level flag is false with empty domains
         (keeping the two consistent → avoids ITMS-91064). The ATT prompt + the
         App Store "App Privacy" label still reflect the SDK's tracking. -->
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>
    <!-- First-party app collects no data itself; SDKs declare their own collection. -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>
    <!-- Required-reason API usage by the app itself. -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <!-- UserDefaults: store the player's settings & game progress. -->
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
